generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                 String                @id @default(cuid())
  // Link to Supabase auth.users.id (UUID). Used for API auth + entitlements.
  supabaseUserId      String?               @unique
  email              String                @unique
  emailVerifiedAt    DateTime?
  name               String?
  imageUrl           String?
  role               UserRole              @default(USER)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  entitlements       CategoryEntitlement[]
  oauthAccounts      OAuthAccount[]
  passwordCredential PasswordCredential?
  payments           Payment[]
  apiKeys            ApiKey[]
  refreshTokens      RefreshToken[]
  toolRuns           ToolRun[]
  adminAuditLogs     AdminAuditLog[]
}

model ApiKey {
  id           String   @id @default(cuid())
  userId       String
  name         String
  keyPrefix    String
  keyHash      String   @unique
  lastUsedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyPrefix])
}

model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CategoryEntitlement {
  id                     String             @id @default(cuid())
  userId                 String
  category               ToolCategory
  status                 SubscriptionStatus
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  razorpaySubscriptionId String?            @unique
  razorpayPlanId         String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([category])
}

model Payment {
  id                String          @id @default(cuid())
  userId            String
  provider          PaymentProvider
  status            PaymentStatus
  amount            Int
  currency          String
  category          ToolCategory?
  razorpayPaymentId String?         @unique
  razorpayOrderId   String?
  razorpayInvoiceId String?
  rawPayload        Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
}

model WebhookEvent {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventType   String
  eventId     String?
  signature   String?
  payload     Json
  receivedAt  DateTime        @default(now())
  processedAt DateTime?
  error       String?

  @@unique([provider, eventId])
  @@index([provider])
  @@index([eventType])
}

model AdminAuditLog {
  id              String   @id @default(cuid())
  actorUserId     String
  actorEmail      String?
  action          String
  targetEmail     String?
  category        ToolCategory?
  metadata        Json?
  createdAt       DateTime @default(now())

  actorUser User @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model Tool {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  category    ToolCategory
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  runs        ToolRun[]

  @@index([category])
}

model ToolRun {
  id        String   @id @default(cuid())
  userId    String
  toolId    String
  createdAt DateTime @default(now())
  tool      Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolId])
}

enum UserRole {
  USER
  ADMIN
}

enum ToolCategory {
  MARKETING
  DEV_ASSISTANT
  ECOM_IMAGE
  SEO_GROWTH
  BUSINESS_AUTOMATION
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  EXPIRED
  INCOMPLETE
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}
